\BKM@entry{id=23,dest={73756273656374696F6E2E352E32},srcline={323}}{5C3337365C3337375C3030304D5C3030306F5C303030765C303030695C3030306E5C303030675C3030305C3034305C303030415C303030765C303030655C303030725C303030615C303030675C30303065}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Collocation Method}{13}{subsection.5.1}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Moving Average}{13}{subsection.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Moving average over the true MRT function, we find that it matches the estimated MRT quite well. We numerically found the optimal window size which resulted in the smallest absolute error between the moving average and the estimated MRT.}}{13}{figure.caption.3}\protected@file@percent }
\newlabel{fig:moving-average-1}{{3}{13}{Moving average over the true MRT function, we find that it matches the estimated MRT quite well. We numerically found the optimal window size which resulted in the smallest absolute error between the moving average and the estimated MRT}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Recovered true MRT based on the inverse moving average matrix. We used a constant (equally weighted) moving average with an optimal window size of 901, this was found based on 10000 simulated data points.}}{15}{figure.caption.4}\protected@file@percent }
\newlabel{fig:moving-average-2}{{4}{15}{Recovered true MRT based on the inverse moving average matrix. We used a constant (equally weighted) moving average with an optimal window size of 901, this was found based on 10000 simulated data points}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Recovered true MRT based on the inverse moving average matrix. We used a linear decay (right weighted) moving average with an optimal window size of 137, this was found based on 1000 simulated data points. The mean square error is 58.752.}}{16}{figure.caption.5}\protected@file@percent }
\newlabel{fig:moving-average-3}{{5}{16}{Recovered true MRT based on the inverse moving average matrix. We used a linear decay (right weighted) moving average with an optimal window size of 137, this was found based on 1000 simulated data points. The mean square error is 58.752}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Recovered true MRT based on the inverse moving average matrix. We used a exponential decay (right weighted) moving average with an optimal window size of 184, this was found based on 1000 simulated data points. The mean square error is 54.349, which is slight better than \ref {fig:moving-average-3}.}}{18}{figure.caption.6}\protected@file@percent }
\newlabel{fig:moving-average-4}{{6}{18}{Recovered true MRT based on the inverse moving average matrix. We used a exponential decay (right weighted) moving average with an optimal window size of 184, this was found based on 1000 simulated data points. The mean square error is 54.349, which is slight better than \ref {fig:moving-average-3}}{figure.caption.6}{}}
